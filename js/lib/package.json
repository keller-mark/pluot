{
  "name": "pluot-wrapper",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist-tsc/index.js",
  "publishConfig": {
    "main": "dist/index.js",
    "module": "dist/index.js",
    "exports": {
      ".": {
        "types": "./dist-tsc/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "src",
    "dist",
    "dist-tsc"
  ],
  "scripts": {
    "start": "pnpm -C ../../ run start-tsc",
    "build": "pnpm -C ../../ run build-tsc",
    "bundle": "pnpm exec vite build -c ./vite.config.js",
    "test": "pnpm exec vitest --run -r ../../ --dir ."
  },
  "dependencies": {
    "pluot": "workspace:*",
    "zarrita": "^0.5.3",
    "quick-lru": "^7.0.1",
    "d3-zoom": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-drag": "^3.0.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "vite": "^6.1.1",
    "jsdom": "^26.1.0",
    "vitest-canvas-mock": "^0.3.3",
    "typescript": "^5.9"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0"
  }
}