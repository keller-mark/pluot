---
interface Props {
	title: string;
    href: string;
}

const { title, href } = Astro.props;
---

<footer>
    <p>&copy; {new Date().getFullYear()} <a href={href}>{title}</a></p>
	<p><strong>How to cite: </strong>Keller, M.S., Gehlenborg, N. Pluot: Towards 'write once, run everywhere' visualization software. <i>arXiv</i> (2026).</p>
</footer>

<style>
	footer {
        max-width: 40rem;
        margin-inline: auto;
        padding-block: 5rem;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: .5rem;
    }
</style>
