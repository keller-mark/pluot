{
  "name": "@pluot/core",
  "private": false,
  "version": "0.1.1",
  "description": "Bindings to the Pluot Rust crate for data visualization",
  "license": "Apache-2.0",
  "author": "Mark Keller",
  "homepage": "https://pluot.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keller-mark/pluot.git"
  },
  "type": "module",
  "main": "dist-tsc/index.js",
  "publishConfig": {
    "main": "dist/index.js",
    "module": "dist/index.js",
    "exports": {
      ".": {
        "types": "./dist-tsc/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "src",
    "dist",
    "dist-tsc"
  ],
  "scripts": {
    "start": "pnpm -C ../../ run start-tsc",
    "build": "pnpm -C ../../ run build-tsc",
    "bundle": "pnpm exec vite build -c ./vite.config.js",
    "test": "pnpm exec vitest --run -r ../../ --dir .",
    "copy-fonts": "node scripts/copy-fonts.mjs ../../vendor/urw-core35-fonts ./src/vendored-fonts"
  },
  "dependencies": {
    "pluot": "workspace:*",
    "lightua": "0.1.0",
    "zarrita": "^0.7.3",
    "quick-lru": "^7.0.1",
    "d3-zoom": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-drag": "^3.0.0",
    "dom-2d-camera": "^2.2.6",
    "camera-2d-simple": "^3.0.0",
    "gl-matrix": "^3.4.4",
    "3d-view-controls": "^2.2.2",
    "3d-view": "^2.0.1",
    "has-passive-events": "^1.0.0",
    "mouse-change": "^1.1.1",
    "mouse-event-offset": "^3.0.2",
    "mouse-wheel": "^1.0.2",
    "lz-string": "^1.5.0",
    "lodash-es": "^4.17.23"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "vite": "^6.1.1",
    "jsdom": "^26.1.0",
    "vitest-canvas-mock": "~0.3.3",
    "typescript": "^5.9"
  }
}
