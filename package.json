{
  "name": "root",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "start-demo": "pnpm -r --parallel --filter=!docs start",
    "start-docs": "pnpm -r --parallel --filter=!demo start",
    "clean-start": "pnpm install && pnpm run clean && pnpm run build && pnpm run start-demo",
    "build:ci": "pnpm -r --workspace-concurrency 1 build",
    "build": "pnpm -r astro-sync && pnpm -r build",
    "start-tsc": "tsc -b --watch",
    "build-tsc": "tsc --build",
    "bundle:ci": "pnpm -r --workspace-concurrency 1 bundle",
    "bundle": "pnpm -r bundle",
    "test": "pnpm -r --workspace-concurrency 1 test",
    "lint": "eslint \"packages/**/src/**/*.{js,jsx,ts,tsx}\" \"sites/*/src/**/*.{js,jsx,ts,tsx}\" \"examples/*/src/**/*.{js,jsx,ts,tsx}\"",
    "lint-fix": "eslint --fix \"packages/**/src/**/*.{js,jsx,ts,tsx}\" \"sites/*/src/**/*.{js,jsx,ts,tsx}\" \"examples/*/src/**/*.{js,jsx,ts,tsx}\"",
    "clean": "pnpm -r exec -- rm -rf dist dist-tsc tsconfig.tsbuildinfo",
    "clean-deps": "pnpm -r exec -- rm -rf node_modules",
    "clean-all": "pnpm run clean && pnpm run clean-deps",
    "build-docs": "pnpm -r build-docs",
    "deploy": "wasm-pack build crates/pluot_core --release --target web && pnpm run build && pnpm run build-docs && gh-pages -d bindings-js/docs/dist --cname pluot.dev --nojekyll"
  },
  "keywords": [],
  "author": "",
  "license": "",
  "devDependencies": {
    "vitest": "^3.2.4",
    "vite": "^6.1.1",
    "jsdom": "^26.1.0",
    "vitest-canvas-mock": "^0.3.3",
    "typescript": "^5.9",
    "gh-pages": "^6.3.0"
  },
  "packageManager": "pnpm@9.7.0"
}
